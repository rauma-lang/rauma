use type.checker;

fn help() {
    print("frontend-checker <command>\n");
    print("commands:\n");
    print("  check\n");
    print("  mismatch\n");
}

fn main(args Args) {
    if (args_len(args) <= 1) {
        help();
        return;
    }

    cmd := args_get(args, 1);

    if (str_eq(cmd, "check")) {
        type.checker.check_demo();
        return;
    }

    if (str_eq(cmd, "mismatch")) {
        type.checker.mismatch_demo();
        return;
    }

    print("unknown command\n");
}
