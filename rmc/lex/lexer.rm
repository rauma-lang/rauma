use source.source;
use lex.token;

pub fn is_space(b int) bool {
    if (b == 32) {
        return true;
    }
    if (b == 10) {
        return true;
    }
    if (b == 9) {
        return true;
    }
    if (b == 13) {
        return true;
    }
    return false;
}

pub fn is_alpha(b int) bool {
    if (b >= 65 && b <= 90) {
        return true;
    }
    if (b >= 97 && b <= 122) {
        return true;
    }
    if (b == 95) {
        return true;
    }
    return false;
}

pub fn is_digit(b int) bool {
    return b >= 48 && b <= 57;
}

pub fn is_ident_continue(b int) bool {
    if (is_alpha(b)) {
        return true;
    }
    if (is_digit(b)) {
        return true;
    }
    return false;
}

pub fn next_start(text str, start int) int {
    len := str_len(text);
    i := start;
    while (i < len && is_space(str_byte(text, i))) {
        i += 1;
    }
    return i;
}

pub fn is_fn_keyword(text str, start int, end int) bool {
    if (end - start != 2) {
        return false;
    }
    if (str_byte(text, start) == 102 && str_byte(text, start + 1) == 110) {
        return true;
    }
    return false;
}

pub fn is_return_keyword(text str, start int, end int) bool {
    if (end - start != 6) {
        return false;
    }
    if (str_byte(text, start) == 114 && str_byte(text, start + 1) == 101 &&
        str_byte(text, start + 2) == 116 && str_byte(text, start + 3) == 117 &&
        str_byte(text, start + 4) == 114 && str_byte(text, start + 5) == 110) {
        return true;
    }
    return false;
}

pub fn is_if_keyword(text str, start int, end int) bool {
    if (end - start != 2) {
        return false;
    }
    if (str_byte(text, start) == 105 && str_byte(text, start + 1) == 102) {
        return true;
    }
    return false;
}

pub fn is_else_keyword(text str, start int, end int) bool {
    if (end - start != 4) {
        return false;
    }
    if (str_byte(text, start) == 101 && str_byte(text, start + 1) == 108 &&
        str_byte(text, start + 2) == 115 && str_byte(text, start + 3) == 101) {
        return true;
    }
    return false;
}

pub fn is_while_keyword(text str, start int, end int) bool {
    if (end - start != 5) {
        return false;
    }
    if (str_byte(text, start) == 119 && str_byte(text, start + 1) == 104 &&
        str_byte(text, start + 2) == 105 && str_byte(text, start + 3) == 108 &&
        str_byte(text, start + 4) == 101) {
        return true;
    }
    return false;
}

pub fn is_use_keyword(text str, start int, end int) bool {
    if (end - start != 3) {
        return false;
    }
    if (str_byte(text, start) == 117 && str_byte(text, start + 1) == 115 &&
        str_byte(text, start + 2) == 101) {
        return true;
    }
    return false;
}

pub fn is_add_ident(text str, start int, end int) bool {
    if (end - start != 3) {
        return false;
    }
    if (str_byte(text, start) == 97 && str_byte(text, start + 1) == 100 &&
        str_byte(text, start + 2) == 100) {
        return true;
    }
