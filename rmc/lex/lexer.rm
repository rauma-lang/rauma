}

pub fn is_hello_ident(text str, start int, end int) bool {
    if (end - start != 5) {
        return false;
    }
    if (str_byte(text, start) == 104 && str_byte(text, start + 1) == 101 &&
        str_byte(text, start + 2) == 108 && str_byte(text, start + 3) == 108 &&
