    }
    return false;
}

pub fn is_str_ident(text str, start int, end int) bool {
    if (end - start != 3) {
        return false;
    }
    if (str_byte(text, start) == 115 && str_byte(text, start + 1) == 116 &&
        str_byte(text, start + 2) == 114) {
        return true;
    }
