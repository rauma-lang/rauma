pub fn is_add_ident(text str, start int, end int) bool {
    if (end - start != 3) {
        return false;
    }
    if (str_byte(text, start) == 97 && str_byte(text, start + 1) == 100 &&
        str_byte(text, start + 2) == 100) {
        return true;
    }
    return false;
}

pub fn is_main_ident(text str, start int, end int) bool {
    if (end - start != 4) {
        return false;
    }
    if (str_byte(text, start) == 109 && str_byte(text, start + 1) == 97 &&
        str_byte(text, start + 2) == 105 && str_byte(text, start + 3) == 110) {
        return true;
    }
    return false;
}

pub fn is_a_ident(text str, start int, end int) bool {
    if (end - start != 1) {
        return false;
    }
    return str_byte(text, start) == 97;
}

pub fn is_b_ident(text str, start int, end int) bool {
    if (end - start != 1) {
        return false;
    }
    return str_byte(text, start) == 98;
}

pub fn is_int_ident(text str, start int, end int) bool {
    if (end - start != 3) {
        return false;
    }
    if (str_byte(text, start) == 105 && str_byte(text, start + 1) == 110 &&
        str_byte(text, start + 2) == 116) {
        return true;
    }
    return false;
}

pub fn is_x_ident(text str, start int, end int) bool {
    if (end - start != 1) {
        return false;
    }
    return str_byte(text, start) == 120;
}

pub fn is_print_ident(text str, start int, end int) bool {
    if (end - start != 5) {
        return false;
    }
    if (str_byte(text, start) == 112 && str_byte(text, start + 1) == 114 &&
        str_byte(text, start + 2) == 105 && str_byte(text, start + 3) == 110 &&
        str_byte(text, start + 4) == 116) {
        return true;
    }
    return false;
}

pub fn is_value_ident(text str, start int, end int) bool {
    if (end - start != 5) {
        return false;
    }
    if (str_byte(text, start) == 118 && str_byte(text, start + 1) == 97 &&
        str_byte(text, start + 2) == 108 && str_byte(text, start + 3) == 117 &&
        str_byte(text, start + 4) == 101) {
        return true;
    }
    return false;
}

