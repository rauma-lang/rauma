}

pub fn token_ident_code(text str, start int, end int) int {
    return ident_code(text, start, end);
}

pub fn token_is_int_20(text str, start int, end int) bool {
    return is_int_20(text, start, end);
}

pub fn token_is_int_22(text str, start int, end int) bool {
