pub fn is_greet_ident(text str, start int, end int) bool {
    if (end - start != 5) {
        return false;
    }
    if (str_byte(text, start) == 103 && str_byte(text, start + 1) == 114 &&
        str_byte(text, start + 2) == 101 && str_byte(text, start + 3) == 101 &&
