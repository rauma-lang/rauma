pub fn is_name_ident(text str, start int, end int) bool {
    if (end - start != 4) {
        return false;
    }
    if (str_byte(text, start) == 110 && str_byte(text, start + 1) == 97 &&
        str_byte(text, start + 2) == 109 && str_byte(text, start + 3) == 101) {
        return true;
    }
    return false;
}

pub fn is_str_ident(text str, start int, end int) bool {
    if (end - start != 3) {
        return false;
    }
    if (str_byte(text, start) == 115 && str_byte(text, start + 1) == 116 &&
        str_byte(text, start + 2) == 114) {
        return true;
    }
    return false;
