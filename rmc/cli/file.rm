pub fn print_file_usage() {
    print("usage: rmc demo-file <path>\n");
}

pub fn print_file_info(path str) {
    text := read_file(path);
    len := str_len(text);

    print("file bytes: ");
    print(len);
    print("\n");

    if (len > 0) {
        print("first byte: ");
        print(str_byte(text, 0));
        print("\n");
    } else {
        print("first byte: none\n");
    }
}
