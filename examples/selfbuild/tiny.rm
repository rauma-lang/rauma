fn add(a int, b int) int {
    return a + b;
}

fn sum_to(limit int) int {
    i := 0;
    total := 0;

    while (i < limit) {
        total = total + i;
        i += 1;
    }

    return total;
}

fn main() {
    total := sum_to(5);
    answer := add(total, 32);

    print("tiny self-build\n");

    if (answer == 42) {
        print("ok\n");
    } else {
        print("bad\n");
    }

    print(answer);
    print("\n");
}
